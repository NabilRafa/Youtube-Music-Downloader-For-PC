{
  "name": "yt-downloader",
  "version": "5.0.0",
  "description": "YouTube Audio & Video Downloader",
  "main": "main.js",
  "scripts": {
    "start":   "electron .",
    "build":   "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {},
  "devDependencies": {
    "electron":         "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId":       "com.ytdl.app",
    "productName": "YT Downloader",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "bin/",
        "to":   "bin/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon":   "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon":   "icon.icns"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick":          false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
